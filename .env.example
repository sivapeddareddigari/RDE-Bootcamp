# Billing Agent — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Set EMAIL_ENABLED=true to actually send emails.
# Leave false (default) to log what would be sent without sending.
EMAIL_ENABLED=false

# Gmail requires an App Password (NOT your regular Gmail password).
# How to get one:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable if not already)
#   2. Go to myaccount.google.com → Security → App passwords
#   3. Select "Mail" and "Windows Computer" → Generate
#   4. Paste the 16-character password below (spaces are optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Display name shown in the From header
EMAIL_FROM_NAME=Billing Agent
EMAIL_FROM_ADDR=your-gmail-address@gmail.com

# ── Anthropic API (for Phase 6 LLM agents) ───────────────────────────────────
# If not set, the supervisor falls back to the deterministic pipeline.
# ANTHROPIC_API_KEY=sk-ant-...

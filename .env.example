# Billing Agent — environment configuration
# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# ── Email (SMTP / Outlook / Office 365) ───────────────────────────────────────
# Set EMAIL_ENABLED=true to actually send emails.
# Leave false (default) to log what would be sent without sending.
EMAIL_ENABLED=false

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=billing-agent@yourcompany.com
SMTP_PASSWORD=your-app-password-here

# Optional — defaults to SMTP_USER if omitted
EMAIL_FROM_NAME=Billing Agent
EMAIL_FROM_ADDR=billing-agent@yourcompany.com

# ── Anthropic API (for Phase 6 LLM agents) ───────────────────────────────────
# If not set, the supervisor falls back to the deterministic pipeline.
# ANTHROPIC_API_KEY=sk-ant-...
